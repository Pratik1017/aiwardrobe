MONGODB_URI=mongodb://localhost:27017/ai-wardrobe
JWT_SECRET=your_jwt_secret_key_here
PORT=5000
NODE_ENV=development

# Google Cloud Vision API Configuration
# Set this to the path of your Google Cloud service account JSON file
# Example: /path/to/google-cloud-key.json
GOOGLE_APPLICATION_CREDENTIALS=./config/google-cloud-key.json
